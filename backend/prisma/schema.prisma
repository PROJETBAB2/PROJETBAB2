datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  locale       String   @default("fr")
}

model Table {
  id           Int      @id @default(autoincrement())
  name         String
  capacity     Int
  posX         Int
  posY         Int
  rotation     Int      @default(0)
  shape        String   @default("SQUARE")
  isActive     Boolean  @default(true)

  reservations Reservation[]
}

model Reservation {
  id         Int    @id @default(autoincrement())
  table      Table  @relation(fields: [tableId], references: [id])
  tableId    Int
  date       String
  startTime  String
  endTime    String
  guestName  String
  guestCount Int
  status     String @default("PENDING") // PENDING -> CHECKED_IN ou EXPIRED
  checkedInAt DateTime?
}

model Dish {
  id       Int    @id @default(autoincrement())
  name     String
  price    Float
  imageUrl String @default("")
  isQuick  Boolean @default(false)
}

